# Learn more https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files

# dependencies
node_modules/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native (regenerated by expo prebuild) — anchored to repo root so the local
# expo module sources under modules/**/{ios,android}/ are still tracked.
/android/
/ios/
.kotlin/
# Local expo native module build output (regenerated by gradle/xcode)
modules/**/android/build/
modules/**/android/.gradle/
modules/**/android/.cxx/
modules/**/build/
*.orig.*
*.jks
*.keystore
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files (never commit real secrets/keys/IDs — only *.example is tracked)
.env
.env*.local

# typescript
*.tsbuildinfo

app-example

# Ignore all uppercase MD files (convention for generated docs)
*_GUIDE.md
*_SETUP.md
*_IMPLEMENTATION.md
*_SAFETY.md
*_ANALYSIS.md
*_FINAL.md
TESTFLIGHT_SETUP.md
TESTFLIGHT_SAFETY.md
BACKEND_AUTH.md
API_ENDPOINTS_ANALYSIS.md
AUTHENTICATION_FINAL.md
WEBHOOK_IMPLEMENTATION.md
WEBHOOK_TESTING_GUIDE.md
WEBHOOK_IMPLEMENTATION.md
WEBHOOK_TESTING_GUIDE.md
LIMITS_API_IMPLEMENTATION.md
LIMITS_API_INTEGRATION.md
CLAUDE.md
scripts/
.vercel
